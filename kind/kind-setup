# install Kind

# Download the kind
[ $(uname -m) = x86_64 ] && curl -Lo ./kind https://kind.sigs.k8s.io/dl/v0.31.0/kind-linux-amd64
# Give permission to files
chmod +x ./kind
# move kind
sudo mv ./kind /usr/local/bin/kind
kind --version

# install kubectl

# Download kubectl
curl -LO "https://dl.k8s.io/release/$(curl -L -s https://dl.k8s.io/release/stable.txt)/bin/linux/amd64/kubectl"
# give permission
chmod +x ./kubectl
# move kubectl
sudo mv ./kubectl /usr/local/bin/kubectl
# check version
kubectl version


# create cluster command
kind create cluster --config cluster.yml --name karan-cluster
kubectl get nodes

# set context redirect cluster to kubectl
kubectl config set-context --cluster=kind-karan-cluster





